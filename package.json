{
  "name": "nightbite",
  "version": "0.1.0",
  "description": "Professional Discord moderation and ticket bot",
  "author": "Nightbite",
  "license": "MIT",
  "keywords": [
    "discord",
    "bot",
    "moderation",
    "tickets",
    "commands",
    "slash",
    "utils"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nightbite/nightbite.git"
  },
  "bugs": {
    "url": "https://github.com/nightbite/nightbite/issues"
  },
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "prestart": "node prisma/seed.js",
    "dev": "node src/index.js",
    "lint": "eslint src/ --ext .js",
    "format": "prettier --write src/",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "node src/scripts/test.js"
  },
  "files": [
    "src",
    "prisma",
    "Dockerfile"
  ],
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "discord-html-transcripts": "^3.2.2",
    "dotenv": "^16.3.1",
    "prisma": "^5.3.1",
    "luxon": "^3.4.4"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.3"
  }
}